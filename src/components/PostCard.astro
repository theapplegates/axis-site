---
/**
 * PostCard — image-forward card for post listings.
 *
 * Renders a bordered card with an optional cover image and post metadata.
 * When no image is available (or showImage is false), renders a compact
 * text-only card with no empty placeholder.
 */
import FormattedDate from '@/components/FormattedDate.astro';
import ImageWrapper from '@/components/ImageWrapper.astro';
import { getPostCardAspectRatio } from '@/config';
import type { Post } from '@/types';

interface Props {
  post: Post;
  /** Whether to show the cover image on this card instance. */
  showImage?: boolean;
  /** Override the aspect ratio CSS string (e.g. "16 / 9"). Defaults to config value. */
  aspectRatio?: string;
  /** Extra CSS classes on the outer anchor. */
  class?: string;
  /** Image loading: use "eager" + fetchpriority="high" for hero/LCP. */
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  post,
  showImage = true,
  aspectRatio = getPostCardAspectRatio(),
  class: className = '',
  loading = 'lazy',
  fetchpriority = 'auto',
} = Astro.props;

const { title, description, published, tags } = post.data;

function resolvePostImage(image: string, postId: string): string {
  let clean = image.replace(/^\.\//, '');
  if (clean.startsWith('images/') || clean.startsWith('attachments/')) {
    clean = clean.replace(/^(images|attachments)\//, '');
  }
  if (!clean.toLowerCase().endsWith('.svg') && !clean.toLowerCase().endsWith('.webp')) {
    clean = clean.replace(/\.(jpg|jpeg|png|gif|bmp|tiff|tif)$/i, '.webp');
  }
  return `/posts/${postId}/${clean}`;
}

const imageUrl = post.data.image ? resolvePostImage(post.data.image, post.id) : null;
const hasImage = showImage && !!imageUrl;
---

<a
  href={`/posts/${post.id}/`}
  class:list={['post-card', { 'post-card--has-image': hasImage }, className]}
  data-draft={post.data.draft ? 'true' : undefined}
>
  {hasImage && (
    <div class="post-card__cover" style={`aspect-ratio: ${aspectRatio};`}>
      <ImageWrapper
        src={imageUrl!}
        alt={post.data.imageAlt || title || 'Post thumbnail'}
        class="post-card__img"
        loading={loading}
        fetchpriority={fetchpriority}
        decoding="async"
      />
    </div>
  )}
  <div class="post-card__body">
    <h3 class="post-card__title">{title}</h3>
    {description && (
      <p class="post-card__desc">{description}</p>
    )}
    <div class="post-card__meta">
      <FormattedDate date={new Date(published)} class="post-card__date" short />
      {tags && tags.length > 0 && (
        <div class="post-card__tags">
          {tags.slice(0, 3).map(tag => (
            <span class="inline-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>

<style>
  .post-card {
    display: block;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    overflow: hidden;
    background-color: var(--bg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }

  .post-card:hover {
    border-color: var(--muted);
  }

  .post-card[data-draft] {
    opacity: 0.5;
  }

  /* Cover image */
  .post-card__cover {
    width: 100%;
    overflow: hidden;
    background-color: var(--border);
  }

  .post-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Body */
  .post-card__body {
    padding: 1rem 1.125rem 1.125rem;
  }

  .post-card--has-image .post-card__body {
    padding-top: 0.875rem;
  }

  .post-card__title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0 0 0.375rem;
    color: var(--text);
  }

  .post-card__desc {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0 0 0.625rem;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .post-card__date {
    font-size: 0.75rem;
    color: var(--muted);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .post-card__tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
</style>
