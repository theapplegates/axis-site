---
/**
 * LocalGraph — Interactive D3 force-directed graph showing connected posts.
 * Adapted for Axis (Astro View Transitions, simple CSS variable theming).
 *
 * Requires: graph-data.json generated by scripts/generate-graph-data.js
 * Controlled by: siteConfig.features.localGraph
 */
import { siteConfig } from '@/config';

export interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
const postsBase = siteConfig.routes?.postsBase ?? 'posts';
---

<div
  id="local-graph-container"
  class="local-graph"
  data-slug={currentSlug}
  data-posts-base={postsBase}
>
  <div class="local-graph-actions">
    <button
      id="local-graph-fullscreen-btn"
      class="local-graph-btn"
      title="Expand graph"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
    </button>
  </div>
  <div id="local-graph-content" class="local-graph-canvas"></div>
</div>

<script>
  import * as d3 from "d3";
  import { getGraphThemeColors } from "@/utils/graph-theme-colors";

  interface GraphNode {
    id: string;
    name: string;
    slug?: string;
    type?: string;
    draft?: boolean;
    radius: number;
    group?: string;
    x?: number;
    y?: number;
    fx?: number | null;
    fy?: number | null;
  }

  interface GraphLink {
    source: string | GraphNode;
    target: string | GraphNode;
    value: number;
  }

  interface GraphData {
    nodes: GraphNode[];
    links: GraphLink[];
  }

  let cleanup: (() => void) | null = null;

  function filterLocalGraphData(data: any, slug: string): GraphData {
    if (!slug) return { nodes: [], links: [] };

    const currentNode = data.nodes.find((n: any) => n.id === slug);
    if (!currentNode) return { nodes: [], links: [] };

    const connected = new Set([slug]);
    for (const c of data.connections) {
      if (c.source === slug || c.target === slug) {
        connected.add(c.source);
        connected.add(c.target);
      }
    }

    const nodes = data.nodes
      .filter((n: any) => connected.has(n.id))
      .map((n: any) => ({
        id: n.id,
        name: n.title || n.id,
        slug: n.slug,
        type: n.type || "post",
        draft: n.draft || false,
        radius: Math.max(3, Math.min(8, (n.connections || 0) + 3)),
        group: n.id === slug ? "current" : (n.type || "post"),
      }));

    const links = data.connections
      .filter(
        (c: any) => connected.has(c.source) && connected.has(c.target)
      )
      .map((c: any) => ({ source: c.source, target: c.target, value: 1 }));

    return { nodes, links };
  }

  function renderGraph(container: HTMLElement, data: GraphData, slug: string): (() => void) | null {
    const colors = getGraphThemeColors();
    const width = container.offsetWidth;
    const height = container.offsetHeight;

    if (width === 0 || height === 0) return null;

    const links = data.links.map((d) => ({ ...d }));
    const nodes = data.nodes.map((d) => ({ ...d }));

    const simulation = d3
      .forceSimulation<GraphNode>(nodes)
      .force(
        "link",
        d3
          .forceLink(links)
          .id((d) => (d as GraphNode).id)
          .distance(30)
          .strength(0.2)
      )
      .force("charge", d3.forceManyBody().strength(-100))
      .force(
        "collide",
        d3.forceCollide((d: any) => d.radius + 8)
      )
      .force("radial", d3.forceRadial(80))
      .force("x", d3.forceX(0).strength(0.05))
      .force("y", d3.forceY(0).strength(0.05));

    const svg = d3
      .create("svg")
      .attr("width", width)
      .attr("height", height)
      .attr("viewBox", [-width / 2, -height / 2, width, height])
      .attr("style", "max-width:100%;height:auto;");

    const g = svg.append("g");

    // Zoom
    const zoom = d3
      .zoom()
      .scaleExtent([0.3, 5])
      .on("zoom", (event) => {
        g.attr("transform", event.transform);
        const scale = event.transform.k;
        labels.style("opacity", scale < 0.8 ? 0 : 1);
      });
    svg.call(zoom as any).style("cursor", "default");

    // Links
    const link = g
      .append("g")
      .attr("stroke", colors.linkStroke)
      .attr("stroke-opacity", 0.25)
      .selectAll("line")
      .data(links)
      .join("line")
      .attr("stroke-width", 1);

    // Nodes
    let dragStartX = 0;
    let dragStartY = 0;
    const CLICK_DISTANCE = 5;
    const nodeGroup = g
      .append("g")
      .selectAll("g")
      .data(nodes)
      .join("g")
      .call(
        d3
          .drag<SVGGElement, GraphNode>()
          .on("start", function (event) {
            dragStartX = event.x;
            dragStartY = event.y;
            if (!event.active) simulation!.alphaTarget(0.1).restart();
            event.subject.fx = event.subject.x;
            event.subject.fy = event.subject.y;
          })
          .on("drag", function (event, d) {
            d.fx = event.x;
            d.fy = event.y;
          })
          .on("end", function (event, d) {
            if (!event.active) simulation!.alphaTarget(0);
            event.subject.fx = null;
            event.subject.fy = null;
            const dx = event.x - dragStartX;
            const dy = event.y - dragStartY;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < CLICK_DISTANCE && d.slug != null && d.type) {
              const pb = document.getElementById('local-graph-container')?.dataset.postsBase || 'posts';
              if (d.type === "page" || d.type === "special") {
                window.location.href = d.slug === "home" ? "/" : `/${d.slug}/`;
              } else if (d.type === "tag") {
                window.location.href = `/${pb}/tag/${d.slug}/`;
              } else if (d.type === "doc") {
                window.location.href = `/docs/${d.slug}/`;
              } else {
                window.location.href = `/${d.type}s/${d.slug}/`;
              }
            }
          }) as any
      );

    // Draft nodes get dimmed
    nodeGroup
      .style("opacity", (d: any) => d.draft ? 0.35 : 1);

    // Circles
    nodeGroup
      .append("circle")
      .attr("r", (d) => d.radius)
      .attr("fill", (d) =>
        d.group === "current" ? colors.currentNodeFill : colors.nodeFill
      )
      .attr("fill-opacity", 0.8)
      .attr("stroke", colors.nodeStroke)
      .attr("stroke-width", 0.5)
      .style("cursor", "pointer");

    // Labels
    const labels = nodeGroup
      .append("text")
      .text((d) => d.name)
      .attr("text-anchor", "middle")
      .attr("dy", (d) => `${d.radius + 12}px`)
      .attr("fill", colors.nodeText)
      .style("font-size", "8px")
      .style("pointer-events", "none")
      .style("user-select", "none");

    // Neighbor map
    const neighborMap = new Map<string, Set<string>>();
    for (const l of links) {
      const src = typeof l.source === "object" ? l.source.id : l.source;
      const tgt = typeof l.target === "object" ? l.target.id : l.target;
      if (!neighborMap.has(src)) neighborMap.set(src, new Set());
      if (!neighborMap.has(tgt)) neighborMap.set(tgt, new Set());
      neighborMap.get(src)!.add(tgt);
      neighborMap.get(tgt)!.add(src);
    }

    // Hover effects
    nodeGroup
      .on("mouseover", function (_event, d) {
        const conn = neighborMap.get(d.id) ?? new Set();
        conn.add(d.id);

        link
          .transition()
          .duration(150)
          .attr("stroke", (l: any) =>
            (typeof l.source === "object" ? l.source.id : l.source) ===
              d.id ||
            (typeof l.target === "object" ? l.target.id : l.target) === d.id
              ? colors.highlight
              : colors.linkStroke
          )
          .attr("stroke-opacity", (l: any) =>
            (typeof l.source === "object" ? l.source.id : l.source) ===
              d.id ||
            (typeof l.target === "object" ? l.target.id : l.target) === d.id
              ? 0.8
              : 0.1
          );

        nodeGroup
          .selectAll<SVGCircleElement, GraphNode>("circle")
          .attr("fill-opacity", (n) => (conn.has(n.id) ? 1 : 0.2))
          .attr("fill", (n) =>
            n.id === d.id
              ? colors.highlight
              : n.group === "current"
                ? colors.currentNodeFill
                : colors.nodeFill
          );

        labels
          .transition()
          .duration(150)
          .style("opacity", (n) => (conn.has(n.id) ? 1 : 0.1));
      })
      .on("mouseout", function () {
        link
          .transition()
          .duration(150)
          .attr("stroke", colors.linkStroke)
          .attr("stroke-opacity", 0.25);

        nodeGroup
          .selectAll<SVGCircleElement, GraphNode>("circle")
          .attr("fill", (n) =>
            n.group === "current" ? colors.currentNodeFill : colors.nodeFill
          )
          .attr("fill-opacity", 0.8);

        labels.transition().duration(150).style("opacity", 1);
      });

    // Tick
    simulation.on("tick", () => {
      link
        .attr("x1", (d: any) => d.source.x)
        .attr("y1", (d: any) => d.source.y)
        .attr("x2", (d: any) => d.target.x)
        .attr("y2", (d: any) => d.target.y);

      nodeGroup.attr("transform", (d: any) => `translate(${d.x},${d.y})`);
    });

    container.innerHTML = "";
    container.appendChild(svg.node()!);

    // Fullscreen
    const fsBtn = document.getElementById("local-graph-fullscreen-btn");
    const fsHandler = () => openFullscreen(data, slug);
    fsBtn?.addEventListener("click", fsHandler);

    return () => {
      simulation.stop();
      fsBtn?.removeEventListener("click", fsHandler);
    };
  }

  function openFullscreen(data: GraphData, slug: string) {
    // Pause the small graph while fullscreen is open
    if (cleanup) {
      cleanup();
      cleanup = null;
    }

    const overlay = document.createElement("div");
    overlay.className = "local-graph-fullscreen";
    overlay.innerHTML = `
      <div class="local-graph-fullscreen-header">
        <span style="font-size:0.875rem;font-weight:500;">Local Graph</span>
        <button class="local-graph-btn" id="local-graph-close-fs">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18 18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="local-graph-fs-canvas" style="width:100%;height:calc(100% - 3rem);"></div>
    `;
    document.body.appendChild(overlay);
    document.body.style.overflow = "hidden";

    let fsCleanup: (() => void) | null = null;
    const fsCanvas = overlay.querySelector(
      "#local-graph-fs-canvas"
    ) as HTMLElement;
    if (fsCanvas) {
      requestAnimationFrame(() => {
        fsCleanup = renderGraph(fsCanvas, data, slug);
      });
    }

    const close = () => {
      if (fsCleanup) fsCleanup();
      overlay.remove();
      document.body.style.overflow = "";
      // Re-render the small graph
      const canvas = document.getElementById("local-graph-content");
      if (canvas) {
        cleanup = renderGraph(canvas, data, slug);
      }
    };

    const closeBtn = overlay.querySelector("#local-graph-close-fs");
    closeBtn?.addEventListener("click", close);
    // Escape key to close fullscreen
    const escHandler = (e: KeyboardEvent) => {
      if (e.key === "Escape") {
        close();
        document.removeEventListener("keydown", escHandler);
      }
    };
    document.addEventListener("keydown", escHandler);
  }

  async function initLocalGraph() {
    const container = document.getElementById("local-graph-container");
    if (!container) return;
    if (container.dataset.bound === "true") return;
    container.dataset.bound = "true";

    const slug = container.dataset.slug;
    if (!slug) return;

    const canvas = document.getElementById("local-graph-content");
    if (!canvas) return;

    try {
      const resp = await fetch("/graph/graph-data.json");
      if (!resp.ok) return;
      const rawData = await resp.json();

      const graphData = filterLocalGraphData(rawData, slug);
      if (graphData.nodes.length < 2) {
        container.style.display = "none";
        return;
      }

      cleanup = renderGraph(canvas, graphData, slug);
    } catch {
      container.style.display = "none";
    }
  }

  initLocalGraph();
  document.addEventListener("astro:page-load", initLocalGraph);

  // Clean up on page transition
  document.addEventListener("astro:before-swap", () => {
    if (cleanup) {
      cleanup();
      cleanup = null;
    }
  });
</script>

<style>
  .local-graph {
    position: relative;
    width: 100%;
    max-width: 200px;
    height: 200px;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    background-color: var(--bg);
  }

  .local-graph-canvas {
    width: 100%;
    height: 100%;
    touch-action: none;
  }

  .local-graph-actions {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 10;
    display: flex;
    gap: 0.25rem;
  }

  .local-graph-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .local-graph-btn:hover {
    color: var(--text);
    background-color: var(--border);
  }
</style>

<style is:global>
  .local-graph-fullscreen {
    position: fixed;
    inset: 0;
    z-index: 60;
    background-color: var(--bg);
    display: flex;
    flex-direction: column;
  }

  .local-graph-fullscreen-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    height: 3rem;
  }
</style>
