---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
const prevUrl = currentPage === 2 ? baseUrl : `${baseUrl}/${currentPage - 1}`;
const nextUrl = `${baseUrl}/${currentPage + 1}`;
---

{totalPages > 1 && (
  <nav class="flex items-center justify-between mt-12 text-sm" style="color: var(--muted);" aria-label="Pagination">
    {hasPrev ? (
      <a href={prevUrl} class="hover:opacity-70 transition-opacity" style="color: var(--text);">
        Previous
      </a>
    ) : (
      <span class="opacity-30">Previous</span>
    )}
    <span>
      {currentPage} / {totalPages}
    </span>
    {hasNext ? (
      <a href={nextUrl} class="hover:opacity-70 transition-opacity" style="color: var(--text);">
        Next
      </a>
    ) : (
      <span class="opacity-30">Next</span>
    )}
  </nav>
)}
