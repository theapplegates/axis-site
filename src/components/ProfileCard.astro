---
/**
 * ProfileCard — displays an author avatar, name, and description.
 * Placement and style are driven by siteConfig.profilePicture.
 */
import { siteConfig } from '@/config';

interface Props {
  /** Override placement context (for rendering in different slots). */
  placement?: 'homepage' | 'footer' | 'header';
}

const { placement } = Astro.props;
const cfg = siteConfig.profilePicture;

if (!cfg.enabled) return;

const effectivePlacement = placement ?? cfg.placement;
const sizeMap = { sm: '2rem', md: '3rem', lg: '4rem' };
const avatarSize = sizeMap[cfg.size] ?? '3rem';

// Profile card display name and bio (with fallback to author/description)
// If both name and bio are explicitly set to empty strings, show image only (no info div)
const nameIsExplicitlyEmpty = cfg.name !== undefined && cfg.name !== null && cfg.name.trim() === '';
const bioIsExplicitlyEmpty = cfg.bio !== undefined && cfg.bio !== null && cfg.bio.trim() === '';
const imageOnly = nameIsExplicitlyEmpty && bioIsExplicitlyEmpty;
const displayName = imageOnly ? '' : (cfg.name?.trim() || siteConfig.author);
const displayBio = imageOnly ? '' : (cfg.bio?.trim() || siteConfig.description);

---

{cfg.enabled && (
  <div class:list={['profile-card', `profile-card--${effectivePlacement}`, `profile-card--size-${cfg.size}`]}>
    {cfg.image && (
      <div class="profile-card__avatar-wrap">
        {cfg.url ? (
          <a href={cfg.url} class="profile-card__avatar-link" aria-label={`${siteConfig.author}'s profile`}>
            <img
              src={cfg.image}
              alt={cfg.alt || siteConfig.author}
              class:list={['profile-card__avatar', `profile-card__avatar--${cfg.style}`]}
              style={`width: ${avatarSize}; height: ${avatarSize};`}
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : (
          <img
            src={cfg.image}
            alt={cfg.alt || siteConfig.author}
            class:list={['profile-card__avatar', `profile-card__avatar--${cfg.style}`]}
            style={`width: ${avatarSize}; height: ${avatarSize};`}
            loading="lazy"
            decoding="async"
          />
        )}
      </div>
    )}
    {!imageOnly && (
      <div class="profile-card__info">
        <span class="profile-card__name">{displayName}</span>
        {displayBio && (
          <p class="profile-card__bio">{displayBio}</p>
        )}
      </div>
    )}
  </div>
)}

<style>
  .profile-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 0;
  }

  /* Homepage variant — slightly more spacious */
  .profile-card--homepage {
    padding: 0.5rem 0 1.25rem;
    margin-bottom: 1.5rem;
  }

  /* Footer variant — compact horizontal */
  .profile-card--footer {
    padding: 0.25rem 0;
    gap: 0.625rem;
  }

  /* Header variant — inline, very compact */
  .profile-card--header {
    padding: 0;
    gap: 0.5rem;
    align-items: center;
  }

  .profile-card__avatar-wrap {
    flex-shrink: 0;
  }

  .profile-card__avatar-link {
    display: block;
  }

  .profile-card__avatar {
    display: block;
    object-fit: cover;
    flex-shrink: 0;
  }

  .profile-card__avatar--circle {
    border-radius: 50%;
  }

  .profile-card__avatar--square {
    border-radius: 0.375rem;
  }

  .profile-card__avatar--none {
    border-radius: 0;
  }

  .profile-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .profile-card--header .profile-card__info {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }

  .profile-card__name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text);
    line-height: 1.3;
  }

  .profile-card--footer .profile-card__name,
  .profile-card--header .profile-card__name {
    font-size: 0.8125rem;
  }

  .profile-card__bio {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Hide bio in compact placements */
  .profile-card--header .profile-card__bio {
    display: none;
  }

</style>
