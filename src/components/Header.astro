---
import { siteConfig } from '@/config';
import { socialIconSvg } from '@/utils/icons';
import ProfileCard from '@/components/ProfileCard.astro';
import { themes } from '@/themes/index';

interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const TitleTag = isHome ? 'h1' : 'span';

// Navigation style: 'traditional' shows links in header, 'minimal' hides them
const navStyle = siteConfig.navigation?.style ?? 'traditional';
const showNavLinks = navStyle === 'traditional';

// Build nav links from pages config (only those with showInNav !== false)
const navLinks: Array<{ title: string; url: string; external: boolean; children?: Array<{ title: string; url: string; external: boolean }> }> = [];
for (const page of siteConfig.pages) {
  if (page.showInNav === false) continue;
  const isExternal = page.url.startsWith('http');
  const url = page.url.trim() ? (isExternal ? page.url : (page.url.endsWith('/') ? page.url : `${page.url}/`)) : '';
  const children = (page as any).children?.map((child: any) => {
    const childExternal = child.url.startsWith('http');
    const childUrl = child.url.trim() ? (childExternal ? child.url : (child.url.endsWith('/') ? child.url : `${child.url}/`)) : '';
    return { title: child.title, url: childUrl, external: childExternal };
  });
  navLinks.push({ title: page.title, url, external: isExternal, children });
}

const currentPath = Astro.url.pathname;
const contentWidth = siteConfig.layout?.contentWidth ?? '680px';

// Social links for header
const showSocialInHeader = siteConfig.navigation?.showSocialInHeader ?? false;
const socialLinks = showSocialInHeader ? (siteConfig.navigation?.social ?? []) : [];

// Feature button configuration
const featureButton = siteConfig.featureButton ?? 'theme';

// Theme choices: hide theme UI if only default is available
const allThemeNames = Object.keys(themes);
let availableThemes: string[];
if (siteConfig.availableThemes === 'all') availableThemes = allThemeNames;
else if (Array.isArray(siteConfig.availableThemes)) availableThemes = siteConfig.availableThemes;
else availableThemes = allThemeNames;
const defaultTheme = siteConfig.theme || 'axis';
const hasThemeChoices = availableThemes.filter(t => t !== defaultTheme).length > 0;

// Mobile nav
const mobileNav = siteConfig.navigation?.mobileNav ?? 'minimal';
const showMobileDrawer = mobileNav === 'traditional';

// Serialize nav links for client-side mobile drawer
const navLinksJson = JSON.stringify(navLinks);
---

<header class="site-header">
  <nav class="site-header-nav" style={`max-width: ${contentWidth};`}>
    <div class="header-left">
      <a href="/" class="site-title">
        <TitleTag>{siteConfig.title}</TitleTag>
      </a>
      {showNavLinks && navLinks.length > 0 && (
        <div class="header-nav-links">
          {navLinks.map(link => (
            link.children && link.children.length > 0 ? (
              <div class="nav-dropdown">
                {link.url?.trim() ? (
                  <a
                    href={link.url}
                    class:list={['nav-link nav-dropdown-trigger', { 'nav-link-active': !link.external && (link.url === '/' ? currentPath === '/' : currentPath.startsWith(link.url)) }]}
                    {...(link.external ? { target: '_blank' } : {})}
                    aria-label={link.title ? `${link.title} menu` : 'Menu'}
                  >
                    <span class="visually-hidden" aria-hidden="true">{link.title}</span>
                    {link.title}
                    <svg class="nav-dropdown-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <title>{link.title || 'Expand menu'}</title>
                      <path d="m6 9 6 6 6-6"/>
                    </svg>
                  </a>
                ) : (
                  <span class="nav-link nav-dropdown-trigger" style="cursor: default;">
                    {link.title}
                    <svg class="nav-dropdown-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <title>{link.title || 'Expand menu'}</title>
                      <path d="m6 9 6 6 6-6"/>
                    </svg>
                  </span>
                )}
                <div class="nav-dropdown-menu">
                  {link.children.map(child => (
                    child.url?.trim() ? (
                      <a
                        href={child.url}
                        class:list={['nav-dropdown-item', { 'nav-link-active': !child.external && currentPath.startsWith(child.url) }]}
                        {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                        aria-label={child.title}
                      >
                        {child.title}
                        {child.external && (
                          <svg class="nav-external-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                          </svg>
                        )}
                      </a>
                    ) : (
                      <span class="nav-dropdown-item" style="cursor: default;">{child.title}</span>
                    )
                  ))}
                </div>
              </div>
            ) : (
              link.url?.trim() ? (
                <a
                  href={link.url}
                  class:list={['nav-link', { 'nav-link-active': !link.external && (link.url === '/' ? currentPath === '/' : currentPath.startsWith(link.url)) }]}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  aria-label={link.title || 'Page'}
                >
                  <span class="visually-hidden" aria-hidden="true">{link.title}</span>
                  {link.title}
                  {link.external && (
                    <svg class="nav-external-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                    </svg>
                  )}
                </a>
              ) : (
                <span class="nav-link" style="cursor: default;">
                  {link.title}
                </span>
              )
            )
          ))}
        </div>
      )}
    </div>

    <div class:list={['header-right', { 'has-mobile-drawer': showMobileDrawer }]}>
      {/* Social icon links */}
      {socialLinks.map(link => (
        link.url?.trim() ? (
          <a
            href={link.url}
            target="_blank"
            aria-label={link.title}
            title={link.title}
            class="header-btn"
            set:html={socialIconSvg(link.icon || link.title, { size: 15, title: link.title || 'Social link' })}
          />
        ) : (
          <span
            aria-label={link.title}
            title={link.title}
            class="header-btn"
            style="cursor: default;"
            set:html={socialIconSvg(link.icon || link.title, { size: 15, title: link.title || 'Social link' })}
          />
        )
      ))}

      {/* Profile card in header placement */}
      {siteConfig.profilePicture?.enabled && siteConfig.profilePicture.placement === 'header' && (
        <ProfileCard placement="header" />
      )}

      {/* Feature button */}
      {featureButton === 'theme' && hasThemeChoices && (
        <button
          id="theme-selector-trigger"
          aria-label="Change theme"
          class="header-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Change theme</title>
            <path d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/>
          </svg>
        </button>
      )}

      {featureButton === 'mode' && (
        <button
          id="dark-mode-toggle"
          aria-label="Toggle dark mode"
          class="header-btn"
        >
          <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Toggle dark mode</title>
            <path d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
          </svg>
          <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Toggle dark mode</title>
            <path d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
          </svg>
        </button>
      )}

      {featureButton === 'graph' && (
        <button
          id="graph-view-trigger"
          aria-label="Open knowledge graph"
          class="header-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Open knowledge graph</title>
            <circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/>
            <path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"/><path d="M12 12v3"/>
          </svg>
        </button>
      )}

      {/* Search / Command Palette — always visible */}
      {siteConfig.features.search && (
        <button
          id="command-palette-trigger"
          aria-label="Open command palette (Ctrl+K)"
          class="header-btn header-btn-search header-btn-command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Open command palette</title>
            <path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z" />
          </svg>
          <kbd class="header-btn-search-kbd">K</kbd>
        </button>
      )}

      {/* Hamburger button for mobile drawer (only when mobileNav is 'traditional') */}
      {showMobileDrawer && (
        <button
          id="mobile-menu-trigger"
          aria-label="Open menu"
          class="header-btn mobile-menu-btn"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Open menu</title>
            <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
          </svg>
        </button>
      )}
    </div>
  </nav>
</header>

{/* Mobile drawer overlay + panel */}
{showMobileDrawer && (
  <div id="mobile-drawer-overlay" class="mobile-drawer-overlay" hidden>
    <div id="mobile-drawer" class="mobile-drawer">
      <div class="mobile-drawer-header">
        <div class="mobile-drawer-actions">
          {featureButton === 'graph' && (
            <button id="mobile-drawer-graph" class="header-btn" aria-label="Graph view">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <title>Graph view</title>
                <circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/>
                <path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"/><path d="M12 12v3"/>
              </svg>
            </button>
          )}
          {featureButton === 'theme' && (
            <button id="mobile-drawer-theme" class="header-btn" aria-label="Change theme">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <title>Change theme</title>
                <path d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/>
              </svg>
            </button>
          )}
          {featureButton === 'mode' && (
            <button id="mobile-drawer-mode" class="header-btn" aria-label="Toggle dark mode">
              <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <title>Toggle dark mode</title>
                <path d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
              </svg>
              <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <title>Toggle dark mode</title>
                <path d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
              </svg>
            </button>
          )}
          {siteConfig.features.search && (
            <button id="mobile-drawer-search" class="header-btn header-btn-search header-btn-command" aria-label="Search">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <title>Search</title>
                <path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z" />
              </svg>
              <kbd class="header-btn-search-kbd">K</kbd>
            </button>
          )}
        </div>
        <button id="mobile-drawer-close" class="header-btn" aria-label="Close menu">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>Close menu</title>
            <path d="M6 18 18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <nav class="mobile-drawer-nav" id="mobile-drawer-nav"></nav>
    </div>
  </div>
)}

<script is:inline>
(function() {
  function bindHeaderButtons() {
    // Theme selector trigger
    var themeBtn = document.getElementById('theme-selector-trigger');
    if (themeBtn && !themeBtn.dataset.bound) {
      themeBtn.dataset.bound = 'true';
      themeBtn.addEventListener('click', function() {
        if (window.__openThemeSelector) window.__openThemeSelector();
      });
    }

    // Dark mode toggle
    var modeBtn = document.getElementById('dark-mode-toggle');
    if (modeBtn && !modeBtn.dataset.bound) {
      modeBtn.dataset.bound = 'true';
      // Sync icon state
      function syncModeIcon() {
        var isDark = document.documentElement.classList.contains('dark');
        var sun = modeBtn.querySelector('.icon-sun');
        var moon = modeBtn.querySelector('.icon-moon');
        if (sun) sun.style.display = isDark ? '' : 'none';
        if (moon) moon.style.display = isDark ? 'none' : '';
      }
      syncModeIcon();
      modeBtn.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        if (window.__axisApplyTheme) {
          var t = localStorage.getItem('selectedTheme') || window.__axisDefaultTheme || 'axis';
          window.__axisApplyTheme(t, { persist: false });
        }
        syncModeIcon();
      });
    }

    // Graph view trigger
    var graphBtn = document.getElementById('graph-view-trigger');
    if (graphBtn && !graphBtn.dataset.bound) {
      graphBtn.dataset.bound = 'true';
      graphBtn.addEventListener('click', function() {
        if (window.__openGraphModal) window.__openGraphModal();
      });
    }
  }

  function updateNavLinksTabIndex() {
    var nav = document.querySelector('.header-nav-links');
    if (!nav) return;
    var links = nav.querySelectorAll('a');
    var narrow = window.innerWidth < 540;
    for (var i = 0; i < links.length; i++) {
      if (narrow) links[i].setAttribute('tabindex', '-1');
      else links[i].removeAttribute('tabindex');
    }
  }

  bindHeaderButtons();
  updateNavLinksTabIndex();
  window.addEventListener('resize', updateNavLinksTabIndex);
  document.addEventListener('astro:page-load', function() {
    bindHeaderButtons();
    updateNavLinksTabIndex();
  });
})();
</script>

<script is:inline define:vars={{ navLinksJson, currentPath }}>
(function() {
  var navLinks;
  try { navLinks = JSON.parse(navLinksJson); } catch(e) { return; }

  function buildDrawerNav() {
    var nav = document.getElementById('mobile-drawer-nav');
    if (!nav) return;
    nav.innerHTML = '';

    navLinks.forEach(function(link) {
      var hasChildren = link.children && link.children.length > 0;
      var hasUrl = link.url && link.url.trim();
      var isActive = !link.external && (link.url === '/' ? currentPath === '/' : currentPath.startsWith(link.url));

      var wrapper = document.createElement('div');

      var itemRow = document.createElement('div');
      itemRow.className = 'mobile-nav-item';

      if (hasUrl) {
        var a = document.createElement('a');
        a.href = link.url;
        a.className = 'mobile-nav-link' + (isActive ? ' active' : '');
        a.textContent = link.title;
        if (link.external) {
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.insertAdjacentHTML('beforeend', ' <svg class="nav-external-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>');
        }
        a.addEventListener('click', function() { closeMobileDrawer(); });
        itemRow.appendChild(a);
      } else {
        var span = document.createElement('span');
        span.className = 'mobile-nav-link';
        span.textContent = link.title;
        if (hasChildren) {
          span.style.cursor = 'pointer';
          span.addEventListener('click', function() { toggleChildren(chevron, childContainer); });
        }
        itemRow.appendChild(span);
      }

      var chevron = null;
      var childContainer = null;

      if (hasChildren) {
        chevron = document.createElement('button');
        chevron.className = 'mobile-nav-chevron';
        chevron.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>';
        chevron.addEventListener('click', function() { toggleChildren(chevron, childContainer); });
        itemRow.appendChild(chevron);

        childContainer = document.createElement('div');
        childContainer.className = 'mobile-nav-children';

        link.children.forEach(function(child) {
          var childActive = !child.external && currentPath.startsWith(child.url);
          if (child.url && child.url.trim()) {
            var ca = document.createElement('a');
            ca.href = child.url;
            ca.className = 'mobile-nav-child' + (childActive ? ' active' : '');
            ca.textContent = child.title;
            if (child.external) {
              ca.target = '_blank';
              ca.rel = 'noopener noreferrer';
              ca.insertAdjacentHTML('beforeend', ' <svg class="nav-external-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>');
            }
            ca.addEventListener('click', function() { closeMobileDrawer(); });
            childContainer.appendChild(ca);
          } else {
            var cs = document.createElement('span');
            cs.className = 'mobile-nav-child';
            cs.textContent = child.title;
            childContainer.appendChild(cs);
          }
        });
      }

      wrapper.appendChild(itemRow);
      if (childContainer) wrapper.appendChild(childContainer);
      nav.appendChild(wrapper);
    });
  }

  function toggleChildren(chevron, container) {
    if (!chevron || !container) return;
    var isOpen = container.classList.contains('open');
    container.classList.toggle('open');
    chevron.classList.toggle('expanded');
  }

  function openMobileDrawer() {
    var overlay = document.getElementById('mobile-drawer-overlay');
    if (!overlay) return;
    overlay.hidden = false;
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        overlay.classList.add('open');
      });
    });
    document.body.style.overflow = 'hidden';
  }

  function closeMobileDrawer() {
    var overlay = document.getElementById('mobile-drawer-overlay');
    if (!overlay) return;
    overlay.classList.remove('open');
    setTimeout(function() { overlay.hidden = true; }, 250);
    document.body.style.overflow = '';
  }

  function bindDrawer() {
    var trigger = document.getElementById('mobile-menu-trigger');
    if (trigger && !trigger.dataset.drawerBound) {
      trigger.dataset.drawerBound = 'true';
      trigger.addEventListener('click', openMobileDrawer);
    }

    var closeBtn = document.getElementById('mobile-drawer-close');
    if (closeBtn && !closeBtn.dataset.drawerBound) {
      closeBtn.dataset.drawerBound = 'true';
      closeBtn.addEventListener('click', closeMobileDrawer);
    }

    var overlay = document.getElementById('mobile-drawer-overlay');
    if (overlay && !overlay.dataset.drawerBound) {
      overlay.dataset.drawerBound = 'true';
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeMobileDrawer();
      });
    }

    // Drawer action buttons
    var drawerSearch = document.getElementById('mobile-drawer-search');
    if (drawerSearch && !drawerSearch.dataset.drawerBound) {
      drawerSearch.dataset.drawerBound = 'true';
      drawerSearch.addEventListener('click', function() {
        closeMobileDrawer();
        setTimeout(function() {
          var trigger = document.getElementById('command-palette-trigger');
          if (trigger) trigger.click();
        }, 260);
      });
    }

    var drawerGraph = document.getElementById('mobile-drawer-graph');
    if (drawerGraph && !drawerGraph.dataset.drawerBound) {
      drawerGraph.dataset.drawerBound = 'true';
      drawerGraph.addEventListener('click', function() {
        closeMobileDrawer();
        setTimeout(function() {
          if (window.__openGraphModal) window.__openGraphModal();
        }, 260);
      });
    }

    var drawerTheme = document.getElementById('mobile-drawer-theme');
    if (drawerTheme && !drawerTheme.dataset.drawerBound) {
      drawerTheme.dataset.drawerBound = 'true';
      drawerTheme.addEventListener('click', function() {
        closeMobileDrawer();
        setTimeout(function() {
          if (window.__openThemeSelector) window.__openThemeSelector();
        }, 260);
      });
    }

    var drawerMode = document.getElementById('mobile-drawer-mode');
    if (drawerMode && !drawerMode.dataset.drawerBound) {
      drawerMode.dataset.drawerBound = 'true';
      function syncDrawerModeIcon() {
        var isDark = document.documentElement.classList.contains('dark');
        var sun = drawerMode.querySelector('.icon-sun');
        var moon = drawerMode.querySelector('.icon-moon');
        if (sun) sun.style.display = isDark ? '' : 'none';
        if (moon) moon.style.display = isDark ? 'none' : '';
      }
      syncDrawerModeIcon();
      drawerMode.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        if (window.__axisApplyTheme) {
          var t = localStorage.getItem('selectedTheme') || window.__axisDefaultTheme || 'axis';
          window.__axisApplyTheme(t, { persist: false });
        }
        syncDrawerModeIcon();
        // Also sync the header mode button if it exists
        var headerModeBtn = document.getElementById('dark-mode-toggle');
        if (headerModeBtn) {
          var sun2 = headerModeBtn.querySelector('.icon-sun');
          var moon2 = headerModeBtn.querySelector('.icon-moon');
          if (sun2) sun2.style.display = isDark ? '' : 'none';
          if (moon2) moon2.style.display = isDark ? 'none' : '';
        }
      });
    }

    buildDrawerNav();
  }

  bindDrawer();
  document.addEventListener('astro:page-load', bindDrawer);
})();
</script>

