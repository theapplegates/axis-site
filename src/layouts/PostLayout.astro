---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import LinkedMentions from '@/components/LinkedMentions.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import ImageGalleryManager from '@/components/ImageGalleryManager.astro';
import ImageWrapper from '@/components/ImageWrapper.astro';
import LocalGraph from '@/components/LocalGraph.astro';
import { siteConfig, siteUrl } from '@/config';
import { hasGraphDataForSlug } from '@/utils/graph-data';
import type { Post, Heading } from '@/types';

interface Props {
  post: Post;
  headings: Heading[];
  readingMinutes?: number;
  prevPost?: Post | null;
  nextPost?: Post | null;
  hasMath?: boolean;
}

const { post, headings, readingMinutes, prevPost, nextPost, hasMath = false } = Astro.props;
const { title, published, updated, description, tags, hideTOC, imageOG } = post.data;
function resolvePostImage(image: string, postId: string): string {
  let clean = image.replace(/^\.\//, '');
  if (clean.startsWith('images/') || clean.startsWith('attachments/')) {
    clean = clean.replace(/^(images|attachments)\//, '');
  }
  if (!clean.toLowerCase().endsWith('.svg') && !clean.toLowerCase().endsWith('.webp')) {
    clean = clean.replace(/\.(jpg|jpeg|png|gif|bmp|tiff|tif)$/i, '.webp');
  }
  return `/posts/${postId}/${clean}`;
}

const ogImage = imageOG && post.data.image
  ? resolvePostImage(post.data.image, post.id)
  : `/open-graph/${post.id}.png`;

const maxDepth = siteConfig.features?.tocDepth ?? 4;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= maxDepth);
const showToc = !hideTOC && siteConfig.features?.tableOfContents !== false && tocHeadings.length >= 2;

const showGraph =
  !post.data.hideLocalGraph &&
  siteConfig.features?.localGraph &&
  siteConfig.features?.localGraphPosts !== false &&
  hasGraphDataForSlug(`post:${post.id}`);

const postUrl = siteUrl(`posts/${post.id}`);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteConfig.site.replace(/\/+$/, '')}${ogImage.startsWith('/') ? ogImage : '/' + ogImage}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description || '',
  url: postUrl,
  datePublished: new Date(published).toISOString(),
  ...(updated ? { dateModified: new Date(updated).toISOString() } : {}),
  image: ogImageUrl,
  author: {
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.site,
  },
  publisher: {
    '@type': 'Person',
    name: siteConfig.author,
  },
  ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
};
---

<BaseLayout
  title={title}
  description={description || undefined}
  ogImage={ogImage}
  ogType="article"
  publishedTime={new Date(published).toISOString()}
  tags={tags || undefined}
  jsonLd={jsonLd}
  hasMath={hasMath}
>

  <Container>
    <article class="py-8">
      <a href="/posts/" class="back-link back-link-mobile animate">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 6.5H9.5C11.1569 6.5 12.5 7.84315 12.5 9.5V9.5C12.5 11.1569 11.1569 12.5 9.5 12.5H7.5M2.5 6.5L5.5 9.5M2.5 6.5L5.5 3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Index
      </a>
      <header class="mb-8 animate">
        <h1 class="text-2xl font-semibold tracking-tight mb-2">{title}</h1>
        <div class="flex items-center gap-2 flex-wrap post-meta">
          <FormattedDate
            date={new Date(published)}
            class="text-sm"
            style="color: var(--muted);"
          />
          {updated && new Date(updated).toDateString() !== new Date(published).toDateString() && (
            <span class="text-xs" style="color: var(--muted); opacity: 0.5;">
              updated <FormattedDate date={new Date(updated)} class="text-xs" />
            </span>
          )}
          {siteConfig.features?.readingTime !== false && readingMinutes && (
            <span class="text-xs" style="color: var(--muted); opacity: 0.5;">&middot; {readingMinutes} min read</span>
          )}
          {siteConfig.features?.wordCount && post.body && (
            <span class="text-xs" style="color: var(--muted); opacity: 0.5;">
              &middot; {post.body.split(/\s+/).filter(Boolean).length} words
            </span>
          )}
          {siteConfig.postOptions?.showTags && tags && tags.length > 0 && (
            <>
              <span class="text-xs post-meta-sep" style="color: var(--muted); opacity: 0.5;">&middot;</span>
              <span class="post-tags">
                {tags.map((tag) => (
                  <a href={`/posts/tag/${encodeURIComponent(tag)}/`} class="post-tag">{tag}</a>
                ))}
              </span>
            </>
          )}
        </div>
      </header>

      {/* ─── Cover Image Hero ─── */}
      {/* Cover image uses `data-no-fade` (skip opacity transition — Chrome
          measures LCP at first paint) + `data-stagger="0"` (start sliding
          at the same moment as the first fading element, so it appears
          to lead the cascade rather than sit still while others fade in). */}
      {siteConfig.postOptions?.showCoverImage && post.data.image && post.data.hideCoverImage !== true && (
        <div class="post-cover-hero animate" data-no-fade data-stagger="0">
          <ImageWrapper
            src={resolvePostImage(post.data.image, post.id)}
            alt={post.data.imageAlt || title || 'Post cover'}
            class="post-cover-hero__img"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      )}

      <ImageGalleryManager>
        <div class="prose prose-neutral dark:prose-invert max-w-none animate">
          <slot />
        </div>
      </ImageGalleryManager>

      <div class="mt-16 border-t animate" style="border-color: var(--border);"></div>

      {siteConfig.features?.linkedMentions !== false && <LinkedMentions currentSlug={post.id} />}
      <RelatedPosts currentSlug={post.id} currentTags={tags || []} />

      {siteConfig.features?.postNavigation !== false && (prevPost || nextPost) && (
        <nav class="mt-8 pt-8 animate">
          <div class="flex justify-between gap-4">
            {prevPost ? (
              <a href={`/posts/${prevPost.id}/`} class="group flex-1 min-w-0">
                <span class="text-xs block mb-1" style="color: var(--muted);">Older</span>
                <span class="text-sm group-hover:opacity-70 transition-opacity truncate block" style="color: var(--text);">{prevPost.data.title}</span>
              </a>
            ) : <div class="flex-1" />}
            {nextPost ? (
              <a href={`/posts/${nextPost.id}/`} class="group flex-1 min-w-0 text-right">
                <span class="text-xs block mb-1" style="color: var(--muted);">Newer</span>
                <span class="text-sm group-hover:opacity-70 transition-opacity truncate block" style="color: var(--text);">{nextPost.data.title}</span>
              </a>
            ) : <div class="flex-1" />}
          </div>
        </nav>
      )}
    </article>
  </Container>

  <div class="toc-sidebar animate">
    <a href="/posts/" class="back-link">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 6.5H9.5C11.1569 6.5 12.5 7.84315 12.5 9.5V9.5C12.5 11.1569 11.1569 12.5 9.5 12.5H7.5M2.5 6.5L5.5 9.5M2.5 6.5L5.5 3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Index
    </a>
    {showGraph && (
      <div class="mb-6">
        <LocalGraph currentSlug={`post:${post.id}`} />
      </div>
    )}
    {showToc && <TableOfContents headings={tocHeadings} />}
  </div>
</BaseLayout>

<style>
  .post-cover-hero {
    margin-bottom: 2rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background-color: var(--border);
    aspect-ratio: 16 / 9;
    max-height: 480px;
  }

  .post-cover-hero__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .post-meta-sep {
    flex-shrink: 0;
  }

  .post-tags {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
  }

  .post-tag {
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    opacity: 0.9;
    transition: opacity 0.15s ease, color 0.15s ease;
  }

  .post-tag:hover {
    opacity: 1;
    color: var(--accent);
  }
</style>
