{
  "name": "axis",
  "type": "module",
  "version": "1.1.6",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.12.0 <27",
    "pnpm": ">=10 <11"
  },
  "description": "Axis - a premium Astro theme for personal publishing. Vault CMS-native.",
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('.astro',{recursive:true,force:true})\" && node scripts/sync-images.js && node scripts/generate-graph-data.js && astro dev",
    "build": "node -e \"require('fs').rmSync('.astro',{recursive:true,force:true})\" && node scripts/sync-images.js && node scripts/process-property-redirects.js && node scripts/generate-graph-data.js --production && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync-images": "node scripts/sync-images.js",
    "process-property-redirects": "node scripts/process-property-redirects.js",
    "update": "node scripts/update.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "^0.2.1",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/tailwind": "^6.0.2",
    "@choctawnationofoklahoma/lite-vimeo": "^1.3.1",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/merriweather": "^5.2.11",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "7.0.0-alpha.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "fuse.js": "^7.1.0",
    "hastscript": "^9.0.1",
    "heroicons": "^2.2.0",
    "katex": "^0.16.9",
    "lucide": "^0.577.0",
    "markdown-it": "^14.1.0",
    "medium-zoom": "^1.1.0",
    "mermaid": "^11.1.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.3.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-components": "^0.3.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "sanitize-html": "^2.15.0",
    "satori": "^0.16.2",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^3.4.17",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/typography": "^0.5.16",
    "@types/d3": "^7.4.3",
    "@types/hast": "^3.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.13.0",
    "@types/unist": "^3.0.3",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "vite": "^7"
  }
  }
